// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library" 
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Aluno {
  id              Int @id     @default(autoincrement())
  nome            String
  cpf             String      @unique
  data_nascimento DateTime
  email           String      @unique
  telefone        String?
  data_matricula  DateTime    @default(now())

  matriculas      Matricula[] @relation("AlunoMatriculas")
}

model Curso {
  id          Int         @id @default(autoincrement())
  nome        String
  cod         String      @unique
  valor       Decimal     @db.Decimal(10, 2)
  cobranca    String

  turmas      Turma[]
  matriculas  Matricula[] @relation("CursoMatriculas")
}

model Turma {
  id               Int            @id @default(autoincrement())
  cursoId          Int
  nome             String         @unique
  ano              Int
  numero           Int
  vagasMax         Int
  qtdAlunos        Int
  vagasDisponiveis Int?
  status           String

  curso      Curso        @relation(fields: [cursoId], references: [id])
  matriculas Matricula[]  @relation("TurmaMatriculas")
}

model Matricula {
  id      Int     @id @default(autoincrement())
  alunoId Int
  cursoId Int
  turmaId Int
  nome    String  @unique

  aluno   Aluno   @relation("AlunoMatriculas",fields: [alunoId], references: [id])
  curso   Curso   @relation("CursoMatriculas",fields: [cursoId], references: [id])
  turma   Turma   @relation("TurmaMatriculas",fields: [turmaId], references: [id])
}