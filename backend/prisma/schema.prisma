// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library" 
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id               Int          @id @default(autoincrement())
  fullName         String       @map("nome")
  cpf              String       @unique
  birthDate        DateTime     @map("data_nascimento")
  email            String       @unique
  phone            String?      @map("telefone")
  enrollmentDate   DateTime     @default(now()) @map("data_matricula")
  enrollmentCount  Int          @default(0) @map("quantidadeMatriculas")

  enrollments      Enrollment[] @relation("StudentEnrollments")

  @@map("Aluno")
}

model Course {
  id           Int          @id @default(autoincrement())
  name         String       @map("nome")
  code         String       @unique @map("cod")
  price        Decimal      @db.Decimal(10, 2) @map("valor")
  billingCycle String       @map("cobranca")

  classGroups  ClassGroup[]
  enrollments  Enrollment[] @relation("CourseEnrollments")

  @@map("Curso")
}

model ClassGroup {
  id            Int          @id @default(autoincrement())
  courseId      Int          @map("cursoId")
  name          String       @unique @map("nome")
  year          Int          @map("ano")
  number        Int          @map("numero")
  maxSeats      Int          @map("vagasMax")
  studentCount  Int          @map("qtdAlunos")
  availableSeats Int?        @map("vagasDisponiveis")
  status        String      

  course        Course       @relation(fields: [courseId], references: [id])
  enrollments   Enrollment[] @relation("ClassGroupEnrollments")

  @@map("Turma")
}

model Enrollment {
  id           Int        @id @default(autoincrement())
  studentId    Int        @map("alunoId")
  courseId     Int        @map("cursoId")
  classGroupId Int        @map("turmaId")
  name         String     @unique @map("nome")
  status       String

  student      Student    @relation("StudentEnrollments", fields: [studentId], references: [id])
  course       Course     @relation("CourseEnrollments", fields: [courseId], references: [id])
  classGroup   ClassGroup @relation("ClassGroupEnrollments", fields: [classGroupId], references: [id])

  @@map("Matricula")
}
